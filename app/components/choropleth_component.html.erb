<%# Persisted across Turbo navigations (data-turbo-permanent + stable id): a language switch carries the
    live MapLibre instance + its controller over untouched, so the map does not re-fetch/re-init - it looks
    like nothing happened. Labels inside stay as-is (intended). The element exists on the home page in every
    locale, so Turbo matches and preserves it; pages without it (Methodology) just drop it cleanly. %>
<section id="coverage-map" data-turbo-permanent
         data-controller="choropleth"
         data-choropleth-indicator-code-value="<%= @indicator_code %>"
         data-choropleth-year-value="<%= @year %>"
         data-choropleth-geojson-url-value="<%= geojson_url %>"
         data-action="indicator:selected@window->choropleth#indicatorSelected tab:shown@window->choropleth#tabShown theme:changed@window->choropleth#themeChanged"
         class="rounded-lg border border-edge bg-surface px-2 pb-3 pt-2 shadow-sm md:flex md:min-h-0 md:flex-1 md:flex-col md:px-6 md:pb-6">

  <%# Header above the map box: title (left) / scale (right) on desktop; stacked & centered on mobile. The YEAR is NOT
      here - it lives below the map (above the slider) on BOTH breakpoints - see further down. %>
  <div class="mb-4 flex flex-col items-center gap-2 md:grid md:grid-cols-2 md:items-center md:gap-x-4">
    <%# title - live via indicatorLabel target (name == Indicator#display_name). %>
    <h2 class="min-w-0 max-w-full truncate text-sm font-semibold tracking-tight text-ink md:justify-self-start"
        data-choropleth-target="indicatorLabel"><%= indicator&.display_name || @indicator_code %></h2>
    <%# scale (filled by choropleth_controller#renderLegend) - header, no map overlay. %>
    <div data-choropleth-target="legend" class="hidden items-center gap-2 text-xs text-ink-soft md:justify-self-end"
         style="display:none"></div>
  </div>

  <%# Map box SHAPED to world aspect (≈1.52:1), centered, embedded with breathing room (NOT edge-to-edge). %>
  <%# Mobile: hero with the world aspect (1.52). Desktop: drop the aspect and flex to fill the card's remaining
      height (md:flex-1) so the whole map + slider fit the viewport; the map auto-refits via its ResizeObserver. %>
  <div class="map-box relative mx-auto aspect-[1.52/1] w-full max-w-[820px] overflow-hidden rounded-md border border-edge md:aspect-auto md:min-h-0 md:flex-1">
    <%# Ocean = CSS background (var(--map-bg)) behind a transparent map canvas → re-tints in lockstep with the page
        (WebGL can't pixel-lock to the CSS compositor). Country fills/outlines render in WebGL on top. %>
    <div data-choropleth-target="map" style="height: 100%; width: 100%; background-color: var(--map-bg);"></div>
  </div>

  <%# Selected year - below the map, above the slider, on BOTH breakpoints (desktop now matches the mobile placement). %>
  <div class="mt-3 text-center text-base font-semibold leading-tight text-ink">
    <%= t("coverage_map.year") %> <span class="tabular-nums" data-choropleth-target="yearHeading"><%= @year %></span>
  </div>

  <%# Slider - UNIFIED with mobile on both breakpoints: tight under the year label (mt-1). %>
  <div class="mt-1 px-1">
    <input type="range"
           data-choropleth-target="yearSlider"
           data-action="input->choropleth#yearChanged"
           min="<%= @year %>" max="<%= @year %>" step="1" value="<%= @year %>"
           class="h-2 w-full cursor-pointer appearance-none rounded-full bg-raised"
           aria-label="<%= t('coverage_map.year') %>">
    <%# Labels (both breakpoints): smallest year at the slider's LEFT end, largest at the RIGHT. %>
    <div class="mt-1 flex justify-between text-xs text-ink-muted">
      <span data-choropleth-target="yearMin">-</span>
      <span data-choropleth-target="yearMax">-</span>
    </div>
  </div>
</section>
